APP_ENV=development
APP_DEBUG=false
APP_URL=http://localhost/Nucleus

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=nucleus
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4

FILE_STORAGE_DRIVER=local
STORAGE_LOCAL_ROOT=storage/resources
UPLOAD_MAX_BYTES=104857600
ADMIN_QUOTA_BYTES=5368709120
HANDLER_QUOTA_BYTES=1073741824
RESOURCE_PROJECT_QUOTA_BYTES=5368709120

FTP_HOST=
FTP_PORT=21
FTP_USERNAME=
FTP_PASSWORD=
FTP_ROOT=/storage
FTP_PASSIVE=true
FTP_TIMEOUT=30

MONITORING_QUEUE_TOKEN=change-this-long-random-token

SMTP_HOST=
SMTP_PORT=587
SMTP_AUTH=true
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_SECURE=tls
MAIL_FROM_ADDRESS=noreply@nucleus.local
MAIL_FROM_NAME=Nucleus
